{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Public and private user profile data.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "Unique Firebase Auth UID" },
        "displayName": { "type": "string", "description": "User's full name or alias" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "photoURL": { "type": "string", "description": "URL to user's profile picture" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the profile was created" },
        "updatedAt": { "type": "string", "format": "date-time", "description": "When the profile was last updated" }
      },
      "required": ["userId", "email", "createdAt", "updatedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile document stored by Auth UID."
    }
  }
}
