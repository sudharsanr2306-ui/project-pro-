rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- Entity Validations ---
    function isValidUser(data) {
      return data.keys().hasAll(['userId', 'email', 'createdAt', 'updatedAt'])
        && data.keys().size() >= 4
        && data.userId == request.auth.uid
        && data.email is string && data.email.size() <= 256
        && data.createdAt == request.time
        && data.updatedAt == request.time;
    }

    // --- Collections ---
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // Users shouldn't list all users by default
      
      allow create: if isOwner(userId) 
        && isValidId(userId)
        && isValidUser(incoming());

      allow update: if isOwner(userId)
        && incoming().updatedAt == request.time
        && incoming().createdAt == existing().createdAt
        && incoming().userId == existing().userId
        && (
          incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'updatedAt'])
        );
      
      allow delete: if false;
    }
  }
}
